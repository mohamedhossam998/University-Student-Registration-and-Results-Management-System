		<properties node_id="15" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x02/\x00\x00\x00\xb9\x00\x00\x06S\x00\x00\x030\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x06R\x00\x00\x03/\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x020\x00\x00\x00\xd8\x00\x00\x06R\x00\x00\x03/', 'scriptLibrary': [{'name': 'Table from numpy', 'script': 'import numpy as np\nfrom Orange.data import Table, Domain, ContinuousVariable, DiscreteVariable\n\ndomain = Domain([ContinuousVariable("age"),\n                 ContinuousVariable("height"),\n                 DiscreteVariable("gender", values=("M", "F"))])\narr = np.array([\n  [25, 186, 0],\n  [30, 164, 1]])\nout_data = Table.from_numpy(domain, arr)\n', 'filename': None}], 'scriptText': 'import numpy as np\nfrom Orange.data import Domain, ContinuousVariable, Table\n\n# 1. استخراج البيانات كأرقام (Numpy Arrays) بطريقة متوافقة مع الإصدارات الجديدة\nfailed = np.array(in_data.get_column("NumberOfFailedCourses")).flatten()\nunique = np.array(in_data.get_column("NumberOfUniqueCoursesTaken")).flatten()\n\n# 2. حساب نسبة الفشل بطريقة آمنة\n# بنعمل مصفوفة أصفار وبنقسم فقط لما يكون عدد الكورسات أكبر من صفر\nfail_rate = np.zeros_like(failed, dtype=float)\nmask = unique &gt; 0\nfail_rate[mask] = failed[mask] / unique[mask]\n\n# 3. إنشاء العمود الجديد "Failure_Rate"\nnew_var = ContinuousVariable("Failure_Rate")\n\n# 4. تحديث الـ Domain (إضافة العمود الجديد للقائمة)\nnew_domain = Domain(in_data.domain.attributes + (new_var,), \n                    in_data.domain.class_vars, \n                    in_data.domain.metas)\n\n# 5. إنشاء الجدول النهائي للمخرجات\nout_data = Table.from_table(new_domain, in_data)\nout_data[:, "Failure_Rate"] = fail_rate.reshape(-1, 1)', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
